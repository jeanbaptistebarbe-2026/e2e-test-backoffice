# URL du backoffice testé
BASE_URL=https://qg.swapn.tech/
AUTH0_BASE_URL=https://auth0.tiime.fr

# Compte de test (login Auth0 Tiime)
AUTH_EMAIL=
AUTH_PASSWORD=

# Boîte mail qui reçoit l'OTP (IMAP Gmail / Google Workspace).
# Laisser GMAIL_USER vide pour réutiliser AUTH_EMAIL comme identifiant IMAP.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Expéditeur de l'email contenant le code (défaut : no-reply@apps.tiime.fr pour l'OTP email).
# Pour la MFA SMS : adresse depuis laquelle l'iPhone transfère le SMS vers Gmail.
OTP_SENDER=
