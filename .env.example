# URL du backoffice testé
BASE_URL=https://qg.swapn.tech/
AUTH0_BASE_URL=https://auth0.tiime.fr

# Compte de test (login Auth0 Tiime)
AUTH_EMAIL=
AUTH_PASSWORD=

# MFA par e-mail (Auth0) : le test sélectionne le facteur « E-mail », Auth0 envoie
# le code à l'adresse du compte (= AUTH_EMAIL), lu en IMAP. Aucun téléphone requis.
# GMAIL_APP_PASSWORD = mot de passe d'application du compte (seul secret obligatoire).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Expéditeur du mail OTP Auth0 (défaut intégré : no-reply@apps.tiime.fr)
OTP_SENDER=
